# NanoClaw environment — copy to .env and fill in values.
# Only the keys you need; unset ones disable the matching feature.

# ── Claude credentials (pick one) ──────────────────────────────────────
# API key mode: set your Anthropic API key. The credential proxy injects
# this into container-originated requests; the container never sees the
# real key.
# ANTHROPIC_API_KEY=sk-ant-...

# OAuth mode (Claude.ai Max / Pro subscription):
# CLAUDE_CODE_OAUTH_TOKEN=...

# ── Telegram ───────────────────────────────────────────────────────────
# Single bot (original convention) — JIDs are tg:<chatId>
# TELEGRAM_BOT_TOKEN=123456:abc...

# Multi-bot: one NanoClaw instance can host N named bots. JIDs become
# tg:<name>:<chatId>, where <name> is the token's suffix lowercased
# (non-alphanumerics become '-'). Example: TELEGRAM_BOT_TOKEN_ADAM → name=adam.
# TELEGRAM_BOT_TOKEN_ADAM=123456:abc...
# TELEGRAM_BOT_TOKEN_EVAN=789012:def...

# ── iCloud (CalDAV + CardDAV) ──────────────────────────────────────────
# Apple ID and an app-specific password from appleid.apple.com
# → Sign-In & Security → App-Specific Passwords. Credentials stay on the
# host; the container receives only a bridge-local service URL.
# ICLOUD_APPLE_ID=user@example.com
# ICLOUD_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Ports (override only if the defaults conflict) ─────────────────────
# CREDENTIAL_PROXY_PORT=3001
# CALDAV_SERVICE_PORT=3002
# CARDDAV_SERVICE_PORT=3003

# ── Multi-instance on one checkout ─────────────────────────────────────
# Point a second instance at a separate state root so it keeps its own
# DB, sessions, groups, and IPC directory.
# NANOCLAW_DATA_DIR=/path/to/alt-data
